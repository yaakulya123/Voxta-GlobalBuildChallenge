# Frontend environment variables
# Copy this file to .env and fill in your values

# Backend WebSocket URL (leave empty to use localhost:8000 in dev)
# For production with a tunnel (e.g. Cloudflare/ngrok), set to your tunnel hostname:
#   VITE_BACKEND_URL=your-tunnel-id.trycloudflare.com
#   VITE_BACKEND_URL=your-subdomain.ngrok.io
VITE_BACKEND_URL=
