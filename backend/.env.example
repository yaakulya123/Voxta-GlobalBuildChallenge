# Backend environment variables
# Copy this file to backend/.env and fill in your values

# OpenRouter API key — used for Gemini vision (ASL sign recognition from video frames)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Anthropic API key — used for Claude Haiku (ASL gloss → natural English sentence)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
